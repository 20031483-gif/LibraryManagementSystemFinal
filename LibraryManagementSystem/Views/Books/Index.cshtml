@{
    ViewBag.Title = "Books";
}

<section class="page-section">

    <h1>Books</h1>

    <p>
        Browse available books in the library system.
    </p>

    <div class="book-container">

        <!-- BOOK 1 -->
        <div class="book-card">

            <img src="https://images-na.ssl-images-amazon.com/images/I/81WcnNQ-TBL.jpg"
                 class="book-image" />

            <h3>Introduction to Web Design</h3>

            <p>
                <strong>Author:</strong> John Smith
            </p>

            <p>
                <span class="status available">
                    Available
                </span>
            </p>

            <a href="/Borrow/Index?bookTitle=Introduction%20to%20Web%20Design"
               class="btn-primary">
                Borrow
            </a>

        </div>

        <!-- BOOK 2 -->
        <div class="book-card">

            <img src="https://images-na.ssl-images-amazon.com/images/I/91asIC1fRwL.jpg"
                 class="book-image" />

            <h3>Database Systems</h3>

            <p>
                <strong>Author:</strong> Mary Brown
            </p>

            <p>
                <span class="status borrowed">
                    Borrowed
                </span>
            </p>

            <button class="btn-disabled">
                Borrowed
            </button>

        </div>

        <!-- BOOK 3 -->
        <div class="book-card">

            <img src="https://images-na.ssl-images-amazon.com/images/I/81kqrwS1nNL.jpg"
                 class="book-image" />

            <h3>Software Engineering Basics</h3>

            <p>
                <strong>Author:</strong> David Lee
            </p>

            <p>
                <span class="status available">
                    Available
                </span>
            </p>

            <a href="/Borrow/Index?bookTitle=Software%20Engineering%20Basics"
               class="btn-primary">
                Borrow
            </a>

        </div>

        <!-- BOOK 4 -->
        <div class="book-card">

            <img src="https://images-na.ssl-images-amazon.com/images/I/71dNsRuYL7L.jpg"
                 class="book-image" />

            <h3>Computer Networking</h3>

            <p>
                <strong>Author:</strong> Alex Johnson
            </p>

            <p>
                <span class="status available">
                    Available
                </span>
            </p>

            <a href="/Borrow/Index?bookTitle=Computer%20Networking"
               class="btn-primary">
                Borrow
            </a>

        </div>

    </div>

</section>