@{
    ViewBag.Title = "Librarian Dashboard";
}

<section class="page-section">

    <h1>Librarian Dashboard</h1>

    <p>
        Welcome, @Session["User"].
        This is the librarian/admin dashboard.
    </p>

    <div class="book-container">

        <div class="book-card">

            <h3>Total Books</h3>

            <p style="font-size: 32px;">
                12
            </p>

        </div>

        <div class="book-card">

            <h3>Borrowed Books</h3>

            <p style="font-size: 32px;">
                4
            </p>

        </div>

        <div class="book-card">

            <h3>Returned Books</h3>

            <p style="font-size: 32px;">
                3
            </p>

        </div>

        <div class="book-card">

            <h3>Registered Members</h3>

            <p style="font-size: 32px;">
                8
            </p>

        </div>

    </div>

    <h2>Admin Actions</h2>

    <div class="book-container">

        <!-- MANAGE BOOKS -->
        <div class="book-card">

            <h3>Manage Books</h3>

            <p>
                Add, update or remove books from the library.
            </p>

            <a href="/Books/Index"
               class="btn-primary">
                View Books
            </a>

        </div>

        <!-- BORROW RECORDS -->
        <div class="book-card">

            <h3>Borrow Records</h3>

            <p>
                View borrowed and returned books.
            </p>

            <a href="/Borrow/MyBooks"
               class="btn-primary">
                View Records
            </a>

        </div>

        <!-- REVIEW FEEDBACK -->
        <div class="book-card">

            <h3>Review Feedback</h3>

            <p>
                View feedback submitted by members.
            </p>

            <a href="/Feedback/Review"
               class="btn-primary">
                Review Feedback
            </a>

        </div>

        <!-- SUBMIT FEEDBACK -->
        <div class="book-card">

            <h3>Submit Feedback</h3>

            <p>
                Submit admin or librarian feedback.
            </p>

            <a href="/Feedback/Index"
               class="btn-primary">
                Submit Feedback
            </a>

        </div>

    </div>

</section>