@{
    ViewBag.Title = "Home";
}

<section class="hero-section">
    <h1>Library Management System</h1>

    <p>
        Welcome to our online Library Management System. This platform allows library members
        to browse books, borrow books, reserve books, and manage their reading activities.
        Library administrators can manage books, borrowing records, feedback, and library reports.
    </p>

    <div class="hero-buttons">
        @Html.ActionLink("View Books", "Index", "Books", null, new { @class = "btn-primary" })
        @Html.ActionLink("Borrow Book", "Index", "Borrow", null, new { @class = "btn-secondary" })
        @Html.ActionLink("Give Feedback", "Index", "Feedback", null, new { @class = "btn-secondary" })
        @Html.ActionLink("Login", "Login", "Account", null, new { @class = "btn-primary" })
    </div>
</section>

