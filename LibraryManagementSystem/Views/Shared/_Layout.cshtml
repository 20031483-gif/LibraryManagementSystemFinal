<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewBag.Title - Library Management System</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>

<body>
    <nav class="navbar">
        <div class="navbar-container">

            <div class="logo">
                Library Management System
            </div>

            <ul class="nav-links">
                <li>@Html.ActionLink("Home", "Index", "Home")</li>
                <li>@Html.ActionLink("Books", "Index", "Books")</li>
                <li>@Html.ActionLink("Borrow", "Index", "Borrow")</li>
                <li>@Html.ActionLink("Feedback", "Index", "Feedback")</li>

                <li>@Html.ActionLink("Librarian", "Dashboard", "Librarian")</li>

                <li>@Html.ActionLink("Login", "Login", "Account")</li>
                <li>@Html.ActionLink("Register", "Register", "Account")</li>
            </ul>

        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <p>&copy; 2026 Library Management System | ICT272 Web Design and Development</p>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

</body>
</html>