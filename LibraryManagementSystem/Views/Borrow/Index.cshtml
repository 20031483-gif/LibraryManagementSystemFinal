@{
    ViewBag.Title = "Borrow";
}

<section class="page-section">
    <h1>Borrow Book</h1>

    <p>
        Members can borrow or reserve books online. This page shows a simple borrowing form.
    </p>

    <form class="form-box">
        <label>Member Name</label>
        <input type="text" placeholder="Enter member name" />

        <label>Book Title</label>
        <input type="text" placeholder="Enter book title" />

        <label>Borrow Date</label>
        <input type="date" />

        <label>Return Date</label>
        <input type="date" />

        <button type="submit" class="btn-primary">Submit Borrow Request</button>
    </form>
</section>

