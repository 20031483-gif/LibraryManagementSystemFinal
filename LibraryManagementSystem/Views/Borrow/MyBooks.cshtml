@model List<LibraryManagementSystem.Controllers.BorrowRecord>

@{
    ViewBag.Title = "My Borrowed Books";
}

<section class="page-section">

    <h1>My Borrowed Books</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <p>You have not borrowed any books yet.</p>
    }
    else
    {
        <div class="book-container">

            @foreach (var item in Model)
            {
                <div class="book-card">

                    @if (item.BookTitle == "Introduction to Web Design")
                    {
                        <img src="https://images-na.ssl-images-amazon.com/images/I/81WcnNQ-TBL.jpg"
                             class="book-image" />
                    }

                    else if (item.BookTitle == "Software Engineering Basics")
                    {
                        <img src="https://images-na.ssl-images-amazon.com/images/I/81kqrwS1nNL.jpg"
                             class="book-image" />
                    }

                    else if (item.BookTitle == "Computer Networking")
                    {
                        <img src="https://images-na.ssl-images-amazon.com/images/I/71dNsRuYL7L.jpg"
                             class="book-image" />
                    }

                    else
                    {
                        <img src="https://images-na.ssl-images-amazon.com/images/I/91asIC1fRwL.jpg"
                             class="book-image" />
                    }

                    <h3>@item.BookTitle</h3>

                    <p>
                        <strong>Borrow Date:</strong>
                        @item.BorrowDate
                    </p>

                    <p>
                        <strong>Return Date:</strong>
                        @item.ReturnDate
                    </p>

                    <p>

                        @if (item.Status == "Borrowed")
                        {
                            <span class="status borrowed">
                                Borrowed
                            </span>
                        }
                        else
                        {
                            <span class="status available">
                                Returned
                            </span>
                        }

                    </p>

                    @if (item.Status == "Borrowed")
                    {
                        <a href="/Borrow/ReturnBook?bookTitle=@item.BookTitle"
                           class="btn-primary">
                            Return Book
                        </a>
                    }
                    else
                    {
                        <button class="btn-disabled">
                            Returned
                        </button>
                    }

                </div>
            }

        </div>
    }

</section>